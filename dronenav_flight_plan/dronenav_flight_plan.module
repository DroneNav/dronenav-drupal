 * AJAX callback for Origin Site changes.
 */
function dronenav_flight_plan_origin_site_ajax(
  array &$form,
  FormStateInterface $form_state
): AjaxResponse {

  $response = new AjaxResponse();

  $response->addCommand(
    new ReplaceCommand(
      '#dronenav-departure-droneport-wrapper',
      $form['field_departure_droneport']
    )
  );

  $response->addCommand(
    new ReplaceCommand(
      '#dronenav-flight-path-wrapper',
      $form['field_flight_path']
    )
  );

  return $response;
}

/**
 * AJAX callback for Destination Site changes.
 */
function dronenav_flight_plan_destination_site_ajax(
  array &$form,
  FormStateInterface $form_state
): AjaxResponse {

  $response = new AjaxResponse();

  $response->addCommand(
    new ReplaceCommand(
      '#dronenav-arrival-droneport-wrapper',
      $form['field_arrival_droneport']
    )
  );

  $response->addCommand(
    new ReplaceCommand(
      '#dronenav-flight-path-wrapper',
      $form['field_flight_path']
